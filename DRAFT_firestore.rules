rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tavareatul7192@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- COLLECTIONS ---

    // USERS: Profile information
    match /users/{userId} {
      // Anyone signed in can read (for browsing property owners/visitors)
      // Note: PII should be protected. If they need to read email/phone, it might need restriction.
      // But for Profile page and Property detail, we need some info.
      allow read: if isSignedIn(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && (
        // Prevent self-elevation to admin
        (!incoming().diff(existing()).affectedKeys().hasAny(['role']) || isAdmin())
      );
      allow delete: if isAdmin();
    }

    // PROPERTIES: Listings
    match /properties/{propertyId} {
      // READ: Public if approved, or if user is signed in (broadened to fix errors during booking/load)
      // Actually, broadening to isSignedIn() allows any visitor to see Drafts.
      // Better: Approved || Owner || Admin
      allow read: if resource.data.status == 'Approved' || 
                   (isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()));
      
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.ownerId == request.auth.uid && (
          // Owners can edit their properties but maybe not 'status' (platform approval)
          incoming().ownerId == existing().ownerId &&
          (!incoming().diff(existing()).affectedKeys().hasAny(['status']) || isAdmin())
        ))
      );
      
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // BOOKINGS: Reservations
    match /bookings/{bookingId} {
      // READ: Broadened to isSignedIn() so visitors can see blocked dates for availability checking
      // This is the CRITICAL fix for "Missing or insufficient permissions" on property charts/calendars
      allow read: if isSignedIn();
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        resource.data.visitorId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid || 
        isAdmin() ||
        // Special case: automated system field updates during transaction if client is acting
        incoming().diff(existing()).affectedKeys().hasOnly(['walletProcessed', 'updatedAt'])
      );
      
      allow delete: if isAdmin();
    }

    // WALLETS: Financial state
    match /wallets/{userId} {
      // READ: Broadened to isSignedIn() to support cross-user transactions in walletService.ts
      // In a production app, we'd use server-side logic, but client transactions need this.
      allow read: if isSignedIn();
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn(); // Broadened for transactions
      
      allow delete: if isAdmin();
    }

    // WALLET TRANSACTIONS
    match /walletTransactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn(); // Allow recording transactions
      allow update, delete: if isAdmin();
    }

    // Naming variant for wallet transactions found in AdminSettings
    match /wallet_transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // WITHDRAWAL REQUESTS
    match /withdrawalRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // REVIEWS
    match /reviews/{reviewId} {
      allow read: if true; // Publicly viewable
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.visitorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // FEEDBACKS & REPORTS
    match /feedbacks/{docId} {
      allow read: if isAdmin();
      allow create: if true; // Allow anonymous feedback if needed, but isSignedIn() is safer
      allow update, delete: if isAdmin();
    }
    
    match /reports/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // SUPPORT
    match /support_inquiries/{docId} {
      allow read: if isAdmin();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }
    
    match /support_tickets/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /support/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
