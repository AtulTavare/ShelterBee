// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User's email address
//   - displayName: string (optional) - User's full name
//   - photoURL: string (optional) - URL to user's profile photo
//   - role: string (required) - 'visitor', 'owner', or 'admin'
//   - createdAt: timestamp (required) - Creation time
//
// Collection: properties
// Document ID: {propertyId}
// Fields:
//   - ownerId: string (required) - UID of the property owner
//   - title: string (required) - Title of the property listing
//   - type: string (required) - 'Room', 'PG', 'Full Flat', 'Full Property'
//   - area: string (required) - Short area name
//   - address: string (required) - Exact address
//   - pricePerDay: number (required) - Price per day in INR
//   - photos: list (required) - Array of photo URLs
//   - amenities: list (required) - List of amenities
//   - description: string (required) - Detailed description
//   - status: string (required) - 'Pending', 'Approved', 'Rejected'
//   - createdAt: timestamp (required) - Creation time
//
// Collection: bookings
// Document ID: {bookingId}
// Fields:
//   - propertyId: string (required) - ID of the booked property
//   - visitorId: string (required) - UID of the visitor who booked
//   - ownerId: string (required) - UID of the property owner
//   - checkIn: string (required) - Check-in date
//   - checkOut: string (required) - Check-out date
//   - totalAmount: number (required) - Total amount paid
//   - status: string (required) - 'Confirmed'
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        request.auth.token.email == 'tavareatul7192@gmail.com'
      );
    }
    function isAuthenticated() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && incoming().role == 'visitor' && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && incoming().role == existing().role; // Users can't change their own role
      allow write: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if (resource.data.status == 'Approved' && isAuthenticated()) || (isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && request.resource.data.status == 'Pending';
      allow update: if isAdmin() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && 
        (resource.data.visitorId == request.auth.uid || 
         resource.data.ownerId == request.auth.uid || 
         isAdmin());
      allow create: if isAuthenticated() && request.resource.data.visitorId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && 
        (resource.data.visitorId == request.auth.uid || 
         resource.data.ownerId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.visitorId;
      allow update: if isAdmin() || (isAuthenticated() && 
        get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reply']));
      allow delete: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /walletTransactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /withdrawalRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /bookingFinancials/{bookingId} {
      allow read: if isSignedIn() && (isOwner(resource.data.visitorId) || isOwner(resource.data.ownerId) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
