// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User's email address
//   - displayName: string (optional) - User's full name
//   - photoURL: string (optional) - URL to user's profile photo
//   - role: string (required) - 'visitor', 'owner', or 'admin'
//   - createdAt: timestamp (required) - Creation time
//
// Collection: properties
// Document ID: {propertyId}
// Fields:
//   - ownerId: string (required) - UID of the property owner
//   - title: string (required) - Title of the property listing
//   - type: string (required) - 'Room', 'PG', 'Full Flat', 'Full Property'
//   - area: string (required) - Short area name
//   - address: string (required) - Exact address
//   - pricePerDay: number (required) - Price per day in INR
//   - photos: list (required) - Array of photo URLs
//   - amenities: list (required) - List of amenities
//   - description: string (required) - Detailed description
//   - status: string (required) - 'Pending', 'Approved', 'Rejected'
//   - createdAt: timestamp (required) - Creation time
//
// Collection: bookings
// Document ID: {bookingId}
// Fields:
//   - propertyId: string (required) - ID of the booked property
//   - visitorId: string (required) - UID of the visitor who booked
//   - ownerId: string (required) - UID of the property owner
//   - checkIn: string (required) - Check-in date
//   - checkOut: string (required) - Check-out date
//   - totalAmount: number (required) - Total amount paid
//   - status: string (required) - 'Confirmed'
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        request.auth.token.email == 'tavareatul7192@gmail.com'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && incoming().role == 'visitor' && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && incoming().role == existing().role; // Users can't change their own role
      allow write: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if true; // Publicly viewable
      allow create: if isSignedIn() && isOwner(incoming().ownerId) && incoming().status == 'Pending';
      allow update: if isAdmin() || (
        isOwner(existing().ownerId) && 
        incoming().ownerId == existing().ownerId &&
        incoming().status == 'Pending' && // Owners always reset to Pending on edit
        incoming().diff(existing()).affectedKeys().hasOnly([
          'title', 'type', 'area', 'address', 'pricePerDay', 'deposit', 
          'photos', 'amenities', 'description', 'guests', 'bedrooms', 
          'beds', 'bathrooms', 'gender', 'checkInTime', 'checkOutTime', 
          'submissionType', 'updatedAt', 'aadhaarFront', 'aadhaarBack', 'propertyProof'
        ])
      );
      allow delete: if isAdmin() || isOwner(existing().ownerId);
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.visitorId) || 
        isOwner(resource.data.ownerId) || 
        isAdmin()
      );
      allow create: if isSignedIn() && isOwner(incoming().visitorId);
      allow update: if isAdmin() || (
        isSignedIn() && (isOwner(resource.data.visitorId) || isOwner(resource.data.ownerId))
      );
    }
  }
}
