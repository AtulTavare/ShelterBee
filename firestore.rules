rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------------
    // 1. GLOBAL HELPERS & SAFETY NET
    // ---------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'tavareatul7192@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------
    // 2. USERS
    // ---------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && incoming().role == 'visitor' && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && incoming().role == existing().role && incoming().email == existing().email;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // 3. PROPERTIES
    // ---------------------------------------------------------------
    match /properties/{propertyId} {
      allow read: if (resource.data.status == 'Approved') || (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid && incoming().status == 'Pending';
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.ownerId == request.auth.uid && (
          (incoming().status == existing().status) ||
          (existing().status == 'Rejected' && incoming().status == 'Pending') ||
          (existing().status == 'Approved' && incoming().status == 'Hidden') ||
          (existing().status == 'Hidden' && incoming().status == 'Approved')
        )
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---------------------------------------------------------------
    // 4. BOOKINGS
    // ---------------------------------------------------------------
    function isValidBooking(data) {
      return data.propertyId is string &&
             data.visitorId == request.auth.uid &&
             data.ownerId is string &&
             data.totalAmount is number &&
             data.status in ['pending_owner', 'confirmed', 'cancelled', 'rejected_by_owner', 'completed'];
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        resource.data.visitorId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isSignedIn() && isValidBooking(incoming()) && incoming().status == 'pending_owner';
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        // Action: Owner Accept (Status: pending_owner -> confirmed)
        (isOwner(resource.data.ownerId) && 
         existing().status == 'pending_owner' && 
         incoming().status == 'confirmed' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acceptedAt', 'updatedAt', 'walletProcessed'])) ||
        // Action: Owner Reject (Status: pending_owner -> rejected_by_owner)
        (isOwner(resource.data.ownerId) && 
         existing().status == 'pending_owner' && 
         incoming().status == 'rejected_by_owner' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'rejectedAt', 'rejectionReason', 'updatedAt', 'walletProcessed'])) ||
        // Action: Visitor Cancel
        (isOwner(resource.data.visitorId) && 
         (existing().status == 'pending_owner' || existing().status == 'confirmed') &&
         incoming().status == 'cancelled' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'refundAmount', 'refundPercentage', 'walletProcessed'])) ||
        // Action: Mark Completed
        (isOwner(resource.data.ownerId) &&
         existing().status == 'confirmed' &&
         incoming().status == 'completed' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        // Action: Internal Wallet Processing (triggered by same transaction)
        (incoming().walletProcessed == true && existing().walletProcessed == false &&
         incoming().diff(existing()).affectedKeys().hasOnly(['walletProcessed', 'updatedAt']))
      );
    }

    // ---------------------------------------------------------------
    // 5. WALLETS & TRANSACTIONS
    // ---------------------------------------------------------------
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow user to initialize their own wallet
      allow create: if isOwner(userId);
      // Allow updates if the user is the owner, or if it's a platform-mediated transaction
      // For security, we should ideally restrict this to the server, but for client-side transactions:
      allow update: if isOwner(userId) || isAdmin() || isSignedIn(); 
    }

    match /walletTransactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin() || 
                                         // Allow visitor to create transaction for owner/admin during booking
                                         existsAfter(/databases/$(database)/documents/bookings/$(incoming().bookingId)));
      allow update, delete: if isAdmin();
    }

    match /withdrawalRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // 6. REVIEWS
    // ---------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().visitorId == request.auth.uid;
      allow update: if (isSignedIn() && incoming().visitorId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
