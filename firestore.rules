// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User's email address
//   - displayName: string (optional) - User's full name
//   - photoURL: string (optional) - URL to user's profile photo
//   - role: string (required) - 'visitor', 'owner', or 'admin'
//   - createdAt: timestamp (required) - Creation time
//
// Collection: properties
// Document ID: {propertyId}
// Fields:
//   - ownerId: string (required) - UID of the property owner
//   - title: string (required) - Title of the property listing
//   - type: string (required) - 'Room', 'PG', 'Full Flat', 'Full Property'
//   - area: string (required) - Short area name
//   - address: string (required) - Exact address
//   - pricePerDay: number (required) - Price per day in INR
//   - photos: list (required) - Array of photo URLs
//   - amenities: list (required) - List of amenities
//   - description: string (required) - Detailed description
//   - status: string (required) - 'Pending', 'Approved', 'Rejected'
//   - createdAt: timestamp (required) - Creation time
//
// Collection: bookings
// Document ID: {bookingId}
// Fields:
//   - propertyId: string (required) - ID of the booked property
//   - visitorId: string (required) - UID of the visitor who booked
//   - ownerId: string (required) - UID of the property owner
//   - checkIn: string (required) - Check-in date
//   - checkOut: string (required) - Check-out date
//   - totalAmount: number (required) - Total amount paid
//   - status: string (required) - 'Confirmed'
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------------
    // 1. GLOBAL HELPERS & SAFETY NET
    // ---------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        request.auth.token.email == 'tavareatul7192@gmail.com'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function verifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }

    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------
    // 2. USERS
    // ---------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && incoming().role == 'visitor' && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && incoming().role == existing().role && incoming().email == existing().email;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // 3. PROPERTIES
    // ---------------------------------------------------------------
    match /properties/{propertyId} {
      allow read: if (resource.data.status == 'Approved') || (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid && incoming().status == 'Pending';
      allow update: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid && incoming().status == existing().status);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // 4. BOOKINGS (MISSION CRITICAL)
    // ---------------------------------------------------------------
    function isValidBooking(data) {
      return data.propertyId is string &&
             data.visitorId == request.auth.uid &&
             data.ownerId is string &&
             data.totalAmount is number &&
             data.status in ['pending_owner', 'confirmed', 'cancelled', 'rejected_by_owner', 'completed'];
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.visitorId == request.auth.uid || resource.data.ownerId == request.auth.uid || isAdmin());
      
      allow create: if verifiedUser() && isValidBooking(incoming()) && incoming().status == 'pending_owner';
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        // Action: Owner Accept
        (isOwner(resource.data.ownerId) && 
         existing().status == 'pending_owner' && 
         incoming().status == 'confirmed' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acceptedAt', 'updatedAt'])) ||
        // Action: Owner Reject
        (isOwner(resource.data.ownerId) && 
         existing().status == 'pending_owner' && 
         incoming().status == 'rejected_by_owner' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'rejectedAt', 'rejectionReason', 'refundPercentage', 'refundAmount', 'updatedAt'])) ||
        // Action: Visitor Cancel
        (isOwner(resource.data.visitorId) && 
         (existing().status == 'pending_owner' || existing().status == 'confirmed') &&
         incoming().status == 'cancelled' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
      
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // 5. WALLETS (ATOMICITY GUARANTEED BY ADMIN/SERVER SERVICE)
    // ---------------------------------------------------------------
    match /wallets/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Wallets are and should only be updated by server-side transactions or admins
      allow write: if isAdmin();
    }

    match /walletTransactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /withdrawalRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if verifiedUser() && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /bookingFinancials/{bookingId} {
      allow read: if isSignedIn() && (resource.data.visitorId == request.auth.uid || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if verifiedUser() && incoming().visitorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // 6. REVIEWS
    // ---------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if verifiedUser() && incoming().visitorId == request.auth.uid;
      allow update: if (verifiedUser() && incoming().visitorId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
