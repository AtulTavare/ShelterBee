{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Shelterbee platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "photoURL": { "type": "string", "description": "URL to user's profile photo" },
        "role": { "type": "string", "enum": ["visitor", "owner", "admin"], "description": "User's role on the platform" },
        "createdAt": { "type": "timestamp", "description": "When the user account was created" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Property": {
      "title": "Property",
      "description": "A property listed on Shelterbee.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID of the property owner" },
        "title": { "type": "string", "description": "Title of the property listing" },
        "type": { "type": "string", "enum": ["Room", "PG", "Full Flat", "Full Property"], "description": "Type of property" },
        "area": { "type": "string", "description": "Short area name" },
        "address": { "type": "string", "description": "Exact address (hidden until booked)" },
        "pricePerDay": { "type": "number", "description": "Price per day in INR" },
        "photos": { "type": "array", "items": { "type": "string" }, "description": "Array of photo URLs" },
        "amenities": { "type": "array", "items": { "type": "string" }, "description": "List of amenities" },
        "description": { "type": "string", "description": "Detailed description" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"], "description": "Approval status" },
        "createdAt": { "type": "timestamp", "description": "When the property was listed" }
      },
      "required": ["ownerId", "title", "type", "area", "address", "pricePerDay", "photos", "amenities", "description", "status", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking made by a visitor for a property.",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string", "description": "ID of the booked property" },
        "visitorId": { "type": "string", "description": "UID of the visitor who booked" },
        "ownerId": { "type": "string", "description": "UID of the property owner" },
        "visitorName": { "type": "string", "description": "Name of the main visitor" },
        "visitorContact": { "type": "string", "description": "Contact number of the main visitor" },
        "isWhatsapp": { "type": "boolean", "description": "Whether contact is on WhatsApp" },
        "checkIn": { "type": "timestamp", "description": "Check-in date" },
        "checkOut": { "type": "timestamp", "description": "Check-out date" },
        "nights": { "type": "number", "description": "Number of nights" },
        "totalAmount": { "type": "number", "description": "Total booking amount" },
        "platformCommission": { "type": "number", "description": "25% platform commission" },
        "receivedAmount": { "type": "number", "description": "75% amount received by owner" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"], "description": "Booking status" },
        "guests": { "type": "array", "description": "List of guest and children details" },
        "govIdAcknowledged": { "type": "boolean", "description": "Acknowledgment of carrying government ID" },
        "createdAt": { "type": "timestamp", "description": "When the booking was made" },
        "updatedAt": { "type": "timestamp", "description": "When the booking was last updated" }
      },
      "required": ["propertyId", "visitorId", "ownerId", "visitorName", "visitorContact", "isWhatsapp", "checkIn", "checkOut", "nights", "totalAmount", "platformCommission", "receivedAmount", "status", "guests", "govIdAcknowledged", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/properties/{propertyId}": {
      "schema": { "$ref": "#/entities/Property" },
      "description": "Stores property listings."
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Stores property bookings."
    }
  }
}
